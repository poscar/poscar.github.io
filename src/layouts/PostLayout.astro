---
import BaseLayout from './BaseLayout.astro';
import { formatPostDate } from '../lib/posts';

interface Props {
  title: string;
  date: Date;
}

const { title, date } = Astro.props;
---
<BaseLayout title={`${title} | Oscar A. Perez`} description={title}>
  <div class="container">
    <div class="row">
      <div class="site">
        <h2>{title}</h2>
        <p class="meta">{formatPostDate(date)} by Oscar A. Perez</p>
        <div class="post">
          <slot />
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
